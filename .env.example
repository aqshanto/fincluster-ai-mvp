# Root .env used by docker compose for local development.
APP_ENV=development
SECRET_KEY=replace_with_a_long_random_secret
ADMIN_USERNAME=fincluster_admin
ADMIN_PASSWORD=change_this_local_password
ACCESS_TOKEN_HOURS=12
CORS_ORIGINS=http://localhost:3000

# Local Docker can install and compare XGBoost. Render's ordinary Docker build
# does not pass INSTALL_XGBOOST, so production stays lightweight by default.
INSTALL_XGBOOST=true
LOCAL_MODEL_ALGORITHM=auto

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
EXTERNAL_AI_ENABLED=false
AI_API_TIMEOUT_SECONDS=5
AI_API_MAX_REQUESTS_PER_MINUTE=8

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/telemetry
