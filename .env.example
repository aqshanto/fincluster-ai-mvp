# Root .env used by docker compose for local development.
APP_ENV=development
SECRET_KEY=replace_with_a_long_random_secret
ADMIN_USERNAME=CHANGE_ME_ADMIN_USERNAME
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ACCESS_TOKEN_HOURS=12
CORS_ORIGINS=http://localhost:3000

# Leave blank for local SQLite. Render injects its Internal PostgreSQL URL.
DATABASE_URL=
TELEMETRY_BROADCAST_INTERVAL_SECONDS=1.0

INSTALL_XGBOOST=true
LOCAL_MODEL_ALGORITHM=auto
LOCAL_MODEL_PATH=models/transaction_classifier.joblib

HUMAN_REVIEW_ENABLED=true
HUMAN_REVIEW_CONFIDENCE_THRESHOLD=0.25
HUMAN_REVIEW_FALLBACK_REQUIRED=true

AUTO_RETRAIN_ENABLED=true
AUTO_RETRAIN_MIN_REVIEWED=100
AUTO_RETRAIN_BATCH_SIZE=100
AUTO_RETRAIN_ALGORITHM=auto
AUTO_RETRAIN_MODEL_PATH=models/transaction_classifier.joblib
AUTO_RETRAIN_MIN_SELECTION_SCORE=0.60
AUTO_RETRAIN_MIN_RECALL=0.55
AUTO_RETRAIN_MIN_BALANCED_ACCURACY=0.60
AUTO_RETRAIN_DEMO_MIN_SECONDS=1.0

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
EXTERNAL_AI_ENABLED=false
AI_API_TIMEOUT_SECONDS=5
AI_API_MAX_REQUESTS_PER_MINUTE=8

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/telemetry
