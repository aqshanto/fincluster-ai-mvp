# Copy this file to backend/.env for local development. Never commit backend/.env.
APP_ENV=development
SECRET_KEY=replace_with_random_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password
ACCESS_TOKEN_HOURS=12

# Comma-separated browser origins allowed to call the API / WebSocket.
CORS_ORIGINS=http://localhost:3000,https://fincluster-ai-mvp.vercel.app

# Auto simulation always uses the local ML model and never spends API quota.
# Add a Google AI Studio key only when you want optional Gemini review for
# manually injected transactions.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
EXTERNAL_AI_ENABLED=false
AI_API_TIMEOUT_SECONDS=5
AI_API_MAX_REQUESTS_PER_MINUTE=8
AI_API_CACHE_SIZE=256

# Privacy-aware local dataset collection. Auto traffic is sampled; every manual
# transaction is stored without IP/device/terminal/STAN/RRN identifiers.
AI_DATASET_PATH=data/transactions.db
AI_DATASET_MAX_ROWS=10000
AUTO_DATA_SAMPLE_EVERY=25

# Optional trusted artifact produced by scripts/train_from_collected_data.py
LOCAL_MODEL_PATH=
LOCAL_MODEL_ALGORITHM=auto
