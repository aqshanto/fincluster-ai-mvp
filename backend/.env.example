# Copy this file to backend/.env for native local development. Never commit backend/.env.
APP_ENV=development
SECRET_KEY=replace_with_random_secret
ADMIN_USERNAME=CHANGE_ME_ADMIN_USERNAME
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ACCESS_TOKEN_HOURS=12

# Comma-separated browser origins allowed to call the API / WebSocket.
CORS_ORIGINS=http://localhost:3000,https://fincluster-ai-mvp.vercel.app

# Render PostgreSQL. Leave blank locally to keep using SQLite.
DATABASE_URL=

# Internal simulation remains 10 Hz; full telemetry is sent once per second.
TELEMETRY_BROADCAST_INTERVAL_SECONDS=1.0

# Auto simulation always uses local ML. Docker installs the optional XGBoost
# candidate by default so Random Forest and XGBoost can be compared.
LOCAL_MODEL_ALGORITHM=auto
LOCAL_MODEL_PATH=models/transaction_classifier.joblib

# Manual human-review gate.
HUMAN_REVIEW_ENABLED=true
HUMAN_REVIEW_CONFIDENCE_THRESHOLD=0.25
HUMAN_REVIEW_FALLBACK_REQUIRED=true

# SQLite fallback and privacy-aware collection settings.
AI_DATASET_PATH=data/transactions.db
AI_DATASET_MAX_ROWS=10000
AUTO_DATA_SAMPLE_EVERY=25

# Controlled retraining: first at 100 reviewed rows, then every new 100 rows.
AUTO_RETRAIN_ENABLED=true
AUTO_RETRAIN_MIN_REVIEWED=100
AUTO_RETRAIN_BATCH_SIZE=100
AUTO_RETRAIN_ALGORITHM=auto
AUTO_RETRAIN_MODEL_PATH=models/transaction_classifier.joblib
AUTO_RETRAIN_MIN_SELECTION_SCORE=0.60
AUTO_RETRAIN_MIN_RECALL=0.55
AUTO_RETRAIN_MIN_BALANCED_ACCURACY=0.60
AUTO_RETRAIN_DEMO_MIN_SECONDS=1.0

# Optional Gemini review for manually injected transactions only.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
EXTERNAL_AI_ENABLED=false
AI_API_TIMEOUT_SECONDS=5
AI_API_MAX_REQUESTS_PER_MINUTE=8
AI_API_CACHE_SIZE=256
